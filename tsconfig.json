{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "emitDeclarationOnly": false,
    "noEmit": true
  },
  "include": [
    "apps/**/*",
    "drizzle.config.js"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}